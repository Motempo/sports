# football-data.org — free token: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Optional: Guardian Open Platform for richer news modals
GUARDIAN_API_KEY=

# Improve text in feedback dialog (xAI Grok) — use GROK_API_KEY or XAI_API_KEY
GROK_API_KEY=

# Fallback app slug when page URL has no motempo subdomain (local dev)
NEXT_PUBLIC_MOTEMPO_APP_ID=sports

# Submit Feedback → Linear (team: motempo)
LINEAR_API_KEY=
# Optional — resolved automatically from LINEAR_TEAM_NAME when omitted
LINEAR_TEAM_ID=
LINEAR_TEAM_NAME=motempo

# Deploy context (set by Vercel)
COMMIT_SHA=

# --- Advertising (disabled until network approval) ---
# Apply: https://www.google.com/adsense/  and  https://nitropay.com/publishers/
# After approval: set NEXT_PUBLIC_ADS_ENABLED=true and fill IDs below.
# Block gambling, dating, alcohol, mature, and sports-betting categories in the ad dashboard.
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_ADS_PROVIDER=adsense

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=
NEXT_PUBLIC_ADSENSE_SLOT_MID=
NEXT_PUBLIC_ADSENSE_SLOT_FEED=

# NitroPay (optional — set NEXT_PUBLIC_ADS_PROVIDER=nitro)
NEXT_PUBLIC_NITRO_SITE_ID=
NEXT_PUBLIC_NITRO_PLACEMENT_HEADER=
NEXT_PUBLIC_NITRO_PLACEMENT_MID=
NEXT_PUBLIC_NITRO_PLACEMENT_FEED=
